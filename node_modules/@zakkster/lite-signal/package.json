{
  "name": "@zakkster/lite-signal",
  "version": "1.4.0",
  "description": "Zero-GC reactive graph. Monomorphic object pool, versioned push-pull propagation, 32-bit modular versioning. Built for hot paths and long-running processes.",
  "author": "Zahary Shinikchiev <shinikchiev@yahoo.com>",
  "license": "MIT",
  "type": "module",
  "main": "./Signal.js",
  "module": "./Signal.js",
  "types": "./Signal.d.ts",
  "exports": {
    ".": {
      "types": "./Signal.d.ts",
      "node": "./Signal.js",
      "import": "./Signal.js",
      "default": "./Signal.js"
    }
  },
  "files": [
    "Signal.js",
    "Signal.d.ts",
    "Watch.js",
    "README.md",
    "llms.txt",
    "LICENSE.txt",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test --test-reporter=spec 'test/*.test.mjs'",
    "test:gc": "node --expose-gc --test --test-reporter=spec 'test/*.test.mjs'",
    "test:coverage": "c8 node --test --test-reporter=spec 'test/*.test.mjs'",
    "test:report": "c8 --reporter=lcov --reporter=text node --test --test-reporter=spec 'test/*.test.mjs'",
    "test:hardening": "npm --prefix test/ProfilerTests test",
    "test:hardening:gc": "npm --prefix test/ProfilerTests run test:gc",
    "test:harness": "npm --prefix harness/ProfilerTools test",
    "test:all": "npm test && npm run test:hardening && npm run test:harness",
    "bench": "node --expose-gc bench/benchmark.mjs",
    "bench-reactive": "node --expose-gc bench/benchmarkReactive.mjs",
    "verify": "npm test && npm run bench",
    "gate": "node harness/VersionMatrix/pre-publish.mjs"
  },
  "keywords": [
    "signal",
    "signals",
    "reactive",
    "reactivity",
    "computed",
    "effect",
    "zero-gc",
    "zero-allocation",
    "object-pool",
    "fine-grained",
    "twitch-extension",
    "performance",
    "devtools",
    "introspection",
    "owner-tree"
  ],
  "homepage": "https://github.com/PeshoVurtoleta/lite-signal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/zakkster/lite-signal.git"
  },
  "bugs": {
    "url": "https://github.com/PeshoVurtoleta/lite-signal/issues",
    "email": "shinikchiev@yahoo.com"
  },
  "engines": {
    "node": ">=18"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/PeshoVurtoleta"
  },
  "sideEffects": false,
  "devDependencies": {
    "@zakkster/lite-devtools": "^1.2.0",
    "@zakkster/lite-profiler": "^1.1.0",
    "@zakkster/lite-profiler-signal": "^1.2.0",
    "@zakkster/lite-signal": "^1.3.0 || >=1.4.0-beta.0 || >=1.6.0-preview.0",
    "c8": "^11.0.0",
    "coveralls-next": "^6.0.2"
  },
  "overrides": {
    "@zakkster/lite-time": {
      "@zakkster/lite-signal": "$@zakkster/lite-signal"
    },
    "@zakkster/lite-devtools": {
      "@zakkster/lite-signal": "$@zakkster/lite-signal"
    }
  }
}
